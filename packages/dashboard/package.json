{
  "name": "@arix-code/dashboard",
  "version": "0.2.3",
  "type": "module",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "static"
  ],
  "scripts": {
    "build": "pnpm build:server && pnpm build:fe",
    "build:fe": "vite build",
    "build:server": "tsup && tsc --project tsconfig.build.json --emitDeclarationOnly --declarationDir dist",
    "dev": "vite",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@arix-code/core": "workspace:*",
    "@arix-code/providers": "workspace:*",
    "cors": "^2.8.5",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/react": "^18.3.1",
    "@types/react-dom": "^18.3.0",
    "@types/supertest": "^6.0.2",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.38",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "supertest": "^7.0.0",
    "tailwindcss": "^3.4.3",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5",
    "vite": "^5.2.11",
    "vitest": "^1.6.0"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
