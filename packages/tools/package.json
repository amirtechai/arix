{
  "name": "@arix/tools",
  "version": "0.2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup && tsc --project tsconfig.build.json --emitDeclarationOnly --declarationDir dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@arix/core": "workspace:*",
    "ignore": "^5.3.0",
    "recheck": "^4.5.0",
    "shell-quote": "^1.8.1",
    "simple-git": "^3.27.0"
  },
  "devDependencies": {
    "@types/shell-quote": "^1.7.3",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
