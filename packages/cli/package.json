{
  "name": "@arix-code/cli",
  "version": "0.2.3",
  "description": "Arix CLI",
  "type": "module",
  "bin": {
    "arix": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@arix-code/core": "workspace:*",
    "@arix-code/dashboard": "workspace:*",
    "@arix-code/providers": "workspace:*",
    "@arix-code/tools": "workspace:*",
    "@arix-code/server": "workspace:*",
    "@arix-code/tui": "workspace:*",
    "@arix-code/wiki": "workspace:*",
    "commander": "^12.0.0",
    "ink": "^5.0.0",
    "open": "^10.1.0",
    "react": "^18.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^18.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^1.6.1"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  }
}
