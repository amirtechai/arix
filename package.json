{
  "name": "arix",
  "version": "0.1.0",
  "description": "Provider-agnostic AI coding assistant for the terminal",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/amirtechai/arix.git"
  },
  "keywords": ["ai", "cli", "coding-assistant", "llm", "anthropic", "openai", "ollama"],
  "private": true,
  "scripts": {
    "build": "pnpm gen:skills && pnpm -r build",
    "gen:skills": "tsx scripts/generate-bundled-skills.ts",
    "smoke": "pnpm build && bash scripts/smoke.sh",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint packages/*/src/**/*.ts",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitest/coverage-v8": "^1.6.1",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "tsup": "^8.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
